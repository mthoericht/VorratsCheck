    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest",
    "test:verbose": "vitest --reporter=verbose",
    "test:run": "vitest run",
    "test:integration:api": "vitest run --config vitest.integration-api.config.ts"
